<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/tvCarProfileTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Профиль автомобиля"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Карточка -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Марка и модель -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Марка и модель"
                    android:textSize="13sp"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/tvCarBrandModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    tools:text="Toyota Corolla" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Тип автомобиля"
                    android:textSize="13sp"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/tvVehicleType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    tools:text="sedan" />

                <!-- Год выпуска -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Год выпуска"
                    android:textSize="13sp"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/tvCarYear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    tools:text="2015" />

                <!-- Объём бака -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Объём бака, л"
                    android:textSize="13sp"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/tvTankCapacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    tools:text="55" />

                <!-- Текущий пробег -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Текущий пробег, км"
                    android:textSize="13sp"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/tvCurrentOdometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    tools:text="123 000" />

                <!-- Кнопка -->
                <Button
                    android:id="@+id/btnEditCarProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Редактировать"
                    android:textAllCaps="false"
                    android:layout_marginTop="24dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Подсказка -->
        <TextView
            android:id="@+id/tvCarProfileHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6B7280"
            android:layout_marginTop="12dp"
            tools:text="Создайте профиль автомобиля, чтобы рассчитывать расход топлива." />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvAccountTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Аккаунт"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvAccountStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    tools:text="Вы не вошли в аккаунт" />

                <Button
                    android:id="@+id/btnAuthAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Войти / Зарегистрироваться"
                    android:textAllCaps="false" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>